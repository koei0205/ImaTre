<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:gravity="center"
    android:orientation="vertical"
    android:padding="24dp">

    <TextView
        android:id="@+id/mission_title"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="現在のミッション"
        android:textSize="24sp"
        android:textStyle="bold" />

    <TextView
        android:id="@+id/today_mission_count"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginTop="16dp"
        android:text="今日のミッション回数：0 / 3"
        android:textSize="18sp" />

    <TextView
        android:id="@+id/remaining_mission_count"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginTop="8dp"
        android:text="あと3回できます"
        android:textSize="16sp" />

    <TextView
        android:id="@+id/mission_state_text"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginTop="16dp"
        android:text="ミッション情報を読み込んでいます"
        android:textSize="16sp"
        android:textStyle="bold" />

    <TextView
        android:id="@+id/mission_description"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginTop="24dp"
        android:text="スクワットを20回しよう！"
        android:textSize="20sp" />

    <TextView
        android:id="@+id/mission_remaining_time"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginTop="32dp"
        android:text="残り時間：30:00"
        android:textSize="18sp" />

    <TextView
        android:id="@+id/mission_calories"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginTop="12dp"
        android:text="推定消費カロリー：6.0 kcal"
        android:textSize="18sp" />

    <Button
        android:id="@+id/mission_clear_button"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginTop="32dp"
        android:text="クリア" />

    <Button
        android:id="@+id/start_new_mission_button"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginTop="12dp"
        android:text="新しいミッションを開始" />

</LinearLayout>
